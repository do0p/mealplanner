# The LLM is only used at recipe import/parsing time.
# Choose one provider:
#   ollama    — local model via Ollama (offline, slower on CPU)
#   anthropic — Claude API (fast, paid per token, needs internet)
LLM_PROVIDER=ollama

# --- Ollama settings (used when LLM_PROVIDER=ollama) ---
# Local dev on the host:           http://localhost:11434
# Dev inside WSL (Ollama on host): http://172.17.176.1:11434
# Inside Docker:                   http://host.docker.internal:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT=600

# --- Anthropic settings (used when LLM_PROVIDER=anthropic) ---
# Get a key at https://console.anthropic.com. Pro/Max subscriptions do not
# include API credits — billing is separate (prepaid credits work).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Where the sqlite db and uploaded files are stored.
DATA_DIR=./data
